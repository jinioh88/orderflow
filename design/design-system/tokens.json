{
  "$meta": {
    "name": "orderflow-design-tokens",
    "version": "1.0.0",
    "note": "단일 진실 공급원. 01-foundations.md는 이 값의 의미를 설명한다. 참조 문법: {core.color.blue.600}",
    "layers": ["core", "semantic", "web", "app"]
  },

  "core": {
    "color": {
      "neutral": {
        "0": "#FFFFFF",
        "50": "#F8FAFC",
        "100": "#F1F5F9",
        "200": "#E2E8F0",
        "300": "#CBD5E1",
        "400": "#94A3B8",
        "500": "#64748B",
        "600": "#475569",
        "700": "#334155",
        "800": "#1E293B",
        "900": "#0F172A"
      },
      "blue":   { "50": "#EFF6FF", "100": "#DBEAFE", "300": "#93C5FD", "500": "#3B82F6", "600": "#2563EB", "700": "#1D4ED8", "800": "#1E40AF" },
      "orange": { "50": "#FFF7ED", "100": "#FFEDD5", "300": "#FDBA74", "500": "#F97316", "600": "#EA580C", "700": "#C2410C", "800": "#9A3412" },
      "green":  { "50": "#F0FDF4", "200": "#BBF7D0", "600": "#16A34A", "700": "#15803D" },
      "amber":  { "50": "#FFFBEB", "200": "#FDE68A", "600": "#D97706", "700": "#B45309" },
      "red":    { "50": "#FEF2F2", "200": "#FECACA", "600": "#DC2626", "700": "#B91C1C" },
      "violet": { "50": "#F5F3FF", "200": "#DDD6FE", "600": "#7C3AED", "700": "#6D28D9" },
      "teal":   { "50": "#F0FDFA", "200": "#99F6E4", "600": "#0D9488", "700": "#0F766E" }
    },
    "fontFamily": {
      "base": "Pretendard",
      "fallbackWeb": "system-ui, -apple-system, 'Apple SD Gothic Neo', sans-serif",
      "fallbackApp": "system-default"
    }
  },

  "semantic": {
    "color": {
      "feedback": {
        "success": { "solid": "{core.color.green.600}",  "text": "{core.color.green.700}",  "bg": "{core.color.green.50}" },
        "warning": { "solid": "{core.color.amber.600}",  "text": "{core.color.amber.700}",  "bg": "{core.color.amber.50}" },
        "danger":  { "solid": "{core.color.red.600}",    "text": "{core.color.red.700}",    "bg": "{core.color.red.50}" },
        "info":    { "solid": "{core.color.blue.600}",   "text": "{core.color.blue.700}",   "bg": "{core.color.blue.50}" }
      },
      "orderStatus": {
        "SUBMITTED":        { "label": "제출됨",    "dot": "{core.color.blue.600}",    "text": "{core.color.blue.700}",    "bg": "{core.color.blue.50}" },
        "PENDING_APPROVAL": { "label": "승인 대기", "dot": "{core.color.amber.600}",   "text": "{core.color.amber.700}",   "bg": "{core.color.amber.50}" },
        "APPROVED":         { "label": "승인됨",    "dot": "{core.color.green.600}",   "text": "{core.color.green.700}",   "bg": "{core.color.green.50}" },
        "REJECTED":         { "label": "거절됨",    "dot": "{core.color.red.600}",     "text": "{core.color.red.700}",     "bg": "{core.color.red.50}" },
        "SHIPPED":          { "label": "출하됨",    "dot": "{core.color.violet.600}",  "text": "{core.color.violet.700}",  "bg": "{core.color.violet.50}" },
        "RECEIVED":         { "label": "입고 완료", "dot": "{core.color.teal.600}",    "text": "{core.color.teal.700}",    "bg": "{core.color.teal.50}" },
        "CANCELED":         { "label": "취소됨",    "dot": "{core.color.neutral.400}", "text": "{core.color.neutral.600}", "bg": "{core.color.neutral.100}" }
      }
    }
  },

  "web": {
    "color": {
      "primary":       "{core.color.blue.600}",
      "primaryHover":  "{core.color.blue.700}",
      "primaryBg":     "{core.color.blue.50}",
      "pageBg":        "{core.color.neutral.50}",
      "surface":       "{core.color.neutral.0}",
      "border":        "{core.color.neutral.200}",
      "borderStrong":  "{core.color.neutral.300}",
      "textTitle":     "{core.color.neutral.800}",
      "textBody":      "{core.color.neutral.700}",
      "textCaption":   "{core.color.neutral.500}",
      "textDisabled":  "{core.color.neutral.400}",
      "gridRowAlt":    "{core.color.neutral.50}",
      "gridRowSelected": "{core.color.blue.50}"
    },
    "typography": {
      "display":    { "size": 20, "lineHeight": 28, "weight": 600 },
      "heading":    { "size": 16, "lineHeight": 24, "weight": 600 },
      "bodyMd":     { "size": 14, "lineHeight": 20, "weight": 400 },
      "body":       { "size": 13, "lineHeight": 20, "weight": 400 },
      "bodyStrong": { "size": 13, "lineHeight": 20, "weight": 600 },
      "caption":    { "size": 12, "lineHeight": 16, "weight": 400 },
      "num":        { "size": 13, "lineHeight": 20, "weight": 400, "tabularNums": true },
      "numLg":      { "size": 24, "lineHeight": 32, "weight": 700, "tabularNums": true }
    },
    "spacing": [2, 4, 8, 12, 16, 20, 24, 32, 40, 48],
    "radius": { "sm": 4, "md": 6, "lg": 8, "full": 999 },
    "shadow": {
      "1": "0 1px 2px rgba(15,23,42,0.06)",
      "2": "0 4px 12px rgba(15,23,42,0.10)",
      "3": "0 12px 32px rgba(15,23,42,0.16)"
    },
    "layout": { "minViewport": 1280, "sidebarWidth": 240, "headerHeight": 56 },
    "icon": { "set": "lucide", "sizeDefault": 20, "sizeSm": 16, "sizeGrid": 14, "stroke": 1.5 }
  },

  "app": {
    "color": {
      "primary":        "{core.color.orange.600}",
      "primaryStrong":  "{core.color.orange.700}",
      "primaryBg":      "{core.color.orange.50}",
      "pageBg":         "{core.color.neutral.0}",
      "surfaceAlt":     "{core.color.neutral.50}",
      "border":         "{core.color.neutral.200}",
      "textTitle":      "{core.color.neutral.900}",
      "textBody":       "{core.color.neutral.800}",
      "textCaption":    "{core.color.neutral.600}",
      "textDisabled":   "{core.color.neutral.400}",
      "scanScreenBg":   "{core.color.neutral.900}",
      "scanScreenText": "{core.color.neutral.50}"
    },
    "typography": {
      "display":    { "size": 28, "lineHeight": 36, "weight": 700 },
      "title":      { "size": 22, "lineHeight": 30, "weight": 600 },
      "heading":    { "size": 18, "lineHeight": 26, "weight": 600 },
      "body":       { "size": 16, "lineHeight": 24, "weight": 400 },
      "bodyStrong": { "size": 16, "lineHeight": 24, "weight": 600 },
      "caption":    { "size": 14, "lineHeight": 20, "weight": 400 },
      "numXl":      { "size": 24, "lineHeight": 32, "weight": 700, "tabularNums": true }
    },
    "spacing": [4, 8, 12, 16, 24, 32, 40, 48],
    "radius": { "sm": 8, "md": 12, "lg": 16, "full": 999 },
    "shadow": {
      "1": "0 1px 2px rgba(15,23,42,0.06)",
      "2": "0 4px 12px rgba(15,23,42,0.10)",
      "3": "0 12px 32px rgba(15,23,42,0.16)"
    },
    "touch": { "minTarget": 48, "minGap": 8 },
    "icon": { "set": "material-symbols", "sizeDefault": 24, "sizeInline": 20 }
  },

  "format": {
    "currency": { "prefix": "₩", "thousandSeparator": ",", "decimals": 0, "align": "right" },
    "quantity": { "unitRequired": true, "example": "3 박스" },
    "date": { "absolute": "YYYY-MM-DD", "casualApp": "M월 D일(요일)" },
    "time": { "format": "HH:mm", "hour12": false },
    "relativeTimeMaxHours": 24,
    "countdownUnderMinutes": 60,
    "emptyCell": "–"
  }
}
